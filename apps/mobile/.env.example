# Local: http://YOUR_LAN_IP:3000/api/v1
# Staging: https://YOUR-API.onrender.com/api/v1  (see docs/STAGING_DEPLOY.md)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# From Google Cloud Console → OAuth 2.0 Client ID (Web application type)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# From `npx eas-cli init` under account ahmed5145
EXPO_PUBLIC_EAS_PROJECT_ID=bb385e3a-8199-4ff2-a65a-6f6a4826983a

# Optional override — normally auto-detected (auth.expo.io on phone, localhost on web)
# EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://auth.expo.io/@ahmed5145/returnrider
# Should be the IP address:3000/api/v1
