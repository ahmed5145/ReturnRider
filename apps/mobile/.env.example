EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# From Google Cloud Console → OAuth 2.0 Client ID (Web application type)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# From `npx eas-cli init` — already defaulted in app.config.js if omitted
EXPO_PUBLIC_EAS_PROJECT_ID=aa737750-09c8-4cf8-969c-121feefc9597

# Optional override — normally auto-detected (auth.expo.io on phone, localhost on web)
# EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://auth.expo.io/@ahmedm1/returnrider
# Should be the IP address:3000/api/v1
