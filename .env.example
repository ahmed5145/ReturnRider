# API
NODE_ENV=development
PORT=3000
# Comma-separated origins for production CORS (optional; default allows all)
# CORS_ORIGINS=https://returnrider.app
# EMAIL_SYNC_SCHEDULER_ENABLED=false
DATABASE_URL=postgresql://returnrider:returnrider@localhost:5432/returnrider
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-min-32-chars
ENCRYPTION_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=com.returnrider.app:/oauth2redirect

# EasyPost
EASYPOST_API_KEY=
EASYPOST_WEBHOOK_SECRET=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Apple Wallet (pkpass)
APPLE_PASS_TYPE_ID=pass.com.returnrider.return
APPLE_TEAM_ID=
APPLE_PASS_CERT_PATH=./wallet-certs/pass.pem
APPLE_PASS_KEY_PATH=./wallet-certs/pass.key
APPLE_WWDR_CERT_PATH=./wallet-certs/wwdr.pem

# Google Wallet
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=./wallet-certs/google-service-account.json

# Firebase (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Email worker
EMAIL_WORKER_REDIS_URL=redis://localhost:6379
EMAIL_WORKER_DATABASE_URL=postgresql://returnrider:returnrider@localhost:5432/returnrider
